OMNICREW_GOOGLE_API_KEY="your-gemini-api-key-here"
OMNICREW_LLM_MODEL_NAME="gemini-3.5-flash"
OMNICREW_FIREBASE_PROJECT_ID="omnicrew-ai-2026"

# Local dev: place sa-key.json (Firebase Admin service account key) in the
# project root.  The backend auto-discovers it.  Alternatively, set:
# GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/sa-key.json"
# On GCP infrastructure (Cloud Run, Cloud Functions), credentials are automatic.
